# -----------------------------
# Base Image
# -----------------------------
FROM node:22-alpine

# -----------------------------
# Working Directory
# -----------------------------
WORKDIR /app

# -----------------------------
# Copy package files
# -----------------------------
COPY package*.json ./

# -----------------------------
# Install dependencies
# -----------------------------
RUN npm install

# -----------------------------
# Copy application source
# -----------------------------
COPY . .

# -----------------------------
# Expose backend port
# -----------------------------
EXPOSE 5000

# -----------------------------
# Start development server
# -----------------------------
CMD ["npm", "run", "dev"]