{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{namespace=\"linguistai\"}[5m])",
          "legendFormat": "{{method}} {{route}} {{status}}"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total{namespace=\"linguistai\",status=~\"5..\"}[5m]) / rate(http_requests_total{namespace=\"linguistai\"}[5m]) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Active Pods",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"linguistai\", phase=\"Running\"})"
        }
      ]
    },
    {
      "title": "Response Time (95th percentile)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{namespace=\"linguistai\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{namespace=\"linguistai\"}[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"linguistai\", container!=\"\"}[5m])",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"linguistai\", container!=\"\"}",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Socket.IO Active Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "socketio_active_connections{namespace=\"linguistai\"}"
        }
      ]
    },
    {
      "title": "MongoDB Connection Pool",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "mongodb_connections_active{namespace=\"linguistai\"}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["linguistai", "nodejs", "mern"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "Asia/Kolkata",
  "title": "LinguistAI Overview",
  "uid": "linguistai-overview"
}
